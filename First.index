<!DOCTYPE html>
<html>
<head>
<style>
  body, html {
    margin: 0;
    padding: 0;
    font-family: sans-serif;
    scroll-behavior: smooth;
  }

  /* 1. The Magic Container */
  .scroll-holder {
    height: 100vh;
    overflow-y: scroll;
    scroll-snap-type: y mandatory; /* Makes it snap like an app */
  }

  section {
    height: 100vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: sticky; 
    top: 0;           /* This creates the 'layering' effect */
    scroll-snap-align: start;
    padding: 40px;
    box-sizing: border-box;
    text-align: center;
  }

  /* Section Colors & Style */
  .hero { 
    background: #000; 
    color: white; 
  }
  
  .features { 
    background: #fff; 
    color: #1c1c1c; 
    border-top-left-radius: 30px; 
    border-top-right-radius: 30px;
    box-shadow: 0 -10px 20px rgba(0,0,0,0.1);
  }

  /* Simple Animation for the icons/cards */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1sfr);
    gap: 20px;
    margin-top: 20px;
  }

  .card {
    background: #f4f4f4;
    padding: 20px;
    border-radius: 15px;
    /* This makes them "pop" in when the page loads */
    animation: popIn 0.8s ease forwards;
  }

  @keyframes popIn {
    from { transform: scale(0.8); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .fixed-btn {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    background: #e23744; /* Zomato Red */
    color: white;
    padding: 15px 40px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: bold;
    z-index: 100;
  }
</style>
</head>
<body>

<div class="scroll-holder">
  <section class="hero">
    <h1>zomato</h1>
    <p>India's #1 food delivery app</p>
  </section>

  <section class="features">
    <h2>Better food for more people</h2>
    <div class="card-grid">
      <div class="card">Veg Mode</div>
      <div class="card">Healthy</div>
    </div>
  </section>
</div>



</body>
</html>
